# Database
# NOTE: the port must match docker-compose.yml's db port mapping. This project uses 5433
# on dev machines that already have a local PostgreSQL on 5432. If you copy this file to
# .env, keep 5433 (not 5432) unless you changed the compose port mapping.
DATABASE_URL="postgresql://aura:aura_dev_password@localhost:5433/aura_gem_erp?schema=public"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Per-customer deployment identity (set these before seeding a new company) ───
# Onboarding a new gem company = fresh deployment/database + these values + `npm run seed`.
COMPANY_NAME="Abeywardhane Gems"
COMPANY_LEGAL_NAME=""
COMPANY_ADDRESS=""
COMPANY_PHONE=""
CURRENCY=LKR

# The business owner's account (they run the system themselves)
OWNER_NAME="Abeywardhane"
OWNER_EMAIL="owner@abeywardhanegems.lk"
OWNER_PASSWORD="Abeywardhane@2026"

# Hidden vendor support account (SUPER_ADMIN) — for you, across deployments. Set false to omit.
SEED_SUPPORT_ACCOUNT=true
SUPPORT_EMAIL="support@auragem.lk"
SUPPORT_PASSWORD="Vendor@Support2026"

# Seed a few demo stones on first run (true = sales demo, false = clean handover)
SEED_SAMPLE_DATA=false

# Storage: disk | s3  (s3 works for AWS S3 and Supabase Storage S3-compatible endpoint)
STORAGE_DRIVER=disk
UPLOAD_DIR=./uploads
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=aura-gem-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
